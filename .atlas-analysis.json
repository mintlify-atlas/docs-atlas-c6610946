  "keyFeatures": [
    "One-command bootstrap for fresh machine setup",
    "Secure secrets management with Bitwarden and age encryption",
    "Data-driven Ansible package management",
    "Hybrid work/personal environment support",
    "WSL and Linux native compatibility",
    "Idempotent and tested automation",
    "Conditional Git configuration for multiple identities",
    "GNOME desktop customization"
  ],
  "publicApiSurface": [
    "bootstrap.sh - Initial setup script",
    "chezmoi init --apply - Apply dotfiles",
    "aws_env() - Switch AWS profiles",
    "bw_unlock() - Unlock Bitwarden vault",
    "ansible-playbook site.yml - Run system configuration",
    "chezmoi edit - Edit configuration files",
    "chezmoi diff - Preview changes",
    "chezmoi apply - Apply dotfile changes"
  ]
